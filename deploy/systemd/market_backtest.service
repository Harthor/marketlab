[Unit]
Description=Market Sentiment Lab Backtest Batch 1h
After=network.target
StartLimitIntervalSec=300
StartLimitBurst=5

[Service]
Type=oneshot
EnvironmentFile=/etc/default/market-sentiment-lab
WorkingDirectory=/opt/market-sentiment-lab
ExecStart=/opt/market-sentiment-lab/user_data/scripts/run_backtest_batch_1h.sh
Restart=on-failure
RestartSec=30
User=ubuntu
Group=ubuntu

[Install]
WantedBy=multi-user.target
