{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Freqtrade Experiment Result",
  "type": "object",
  "required": [
    "experiment_id",
    "created_at",
    "status",
    "strategy_name",
    "strategy_family",
    "config_path",
    "timeframe",
    "timerange",
    "universe_label",
    "pairs_count",
    "market_mode",
    "metrics",
    "robustness",
    "artifacts",
    "notes",
    "provenance"
  ],
  "properties": {
    "experiment_id": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "status": {"type": "string", "enum": ["success", "failed", "partial"]},
    "strategy_name": {"type": "string"},
    "strategy_family": {"type": "string"},
    "config_path": {"type": "string"},
    "timeframe": {"type": "string"},
    "timerange": {"type": "string"},
    "universe_label": {"type": "string"},
    "pairs_count": {"type": "integer", "minimum": 0},
    "market_mode": {"type": "string", "enum": ["spot", "futures"]},
    "split_label": {"type": ["string", "null"]},
    "metrics": {
      "type": "object",
      "required": [
        "trades",
        "trades_per_day",
        "profit_total_pct",
        "winrate_pct",
        "profit_factor",
        "max_drawdown_pct"
      ],
      "properties": {
        "trades": {"type": "integer"},
        "trades_per_day": {"type": "number"},
        "profit_total_pct": {"type": "number"},
        "winrate_pct": {"type": "number"},
        "profit_factor": {"type": ["number", "null"]},
        "max_drawdown_pct": {"type": "number"}
      }
    },
    "robustness": {
      "type": "object",
      "required": ["oos", "fee_sensitivity_tested", "fee_delta_pct"],
      "properties": {
        "oos": {"type": ["boolean", "null"]},
        "fee_sensitivity_tested": {"type": "boolean"},
        "fee_delta_pct": {"type": ["number", "null"]}
      }
    },
    "artifacts": {
      "type": "object",
      "required": [
        "backtest_meta_json",
        "backtest_export_json",
        "summary_md",
        "extra_files"
      ],
      "properties": {
        "backtest_meta_json": {"type": ["string", "null"]},
        "backtest_export_json": {"type": ["string", "null"]},
        "summary_md": {"type": ["string", "null"]},
        "extra_files": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "notes": {
      "type": "object",
      "required": ["warnings", "observations"],
      "properties": {
        "warnings": {
          "type": "array",
          "items": {"type": "string"}
        },
        "observations": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["command_run", "git_commit"],
      "properties": {
        "command_run": {"type": "string"},
        "git_commit": {"type": ["string", "null"]}
      }
    }
  }
}
